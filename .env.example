# Auth.js secret — generate with: openssl rand -hex 32
AUTH_SECRET=your_auth_secret_here

# GitHub OAuth App — create at https://github.com/settings/developers
# Callback URL (dev):  http://localhost:5173/auth/callback/github
# Callback URL (prod): https://your-domain.com/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Your GitHub username — only this account will be allowed to log in
ALLOWED_GITHUB_USERNAME=your_github_username

# Optional debug bypass for local and agent-driven Playwright testing
# Set the same strong secret locally and in Vercel if you want the bypass to work in both places
DEBUG_AUTH_BYPASS_ENABLED=
DEBUG_AUTH_BYPASS_SECRET=
DEBUG_AUTH_BYPASS_NAME=Agent

# Neon PostgreSQL — get from https://console.neon.tech
# Use the "pooled" connection string (not the direct connection)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AI keys — only needed when AI features are implemented (skeleton only for now)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Required on Vercel (and any reverse-proxy host) so Auth.js trusts the host header
# Set this to "true" in Vercel's environment variable settings
AUTH_TRUST_HOST=
